DATABASE_URL="postgresql://neondb_owner:dummy_password@ep-dummy-url.us-west-2.aws.neon.tech/neondb?sslmode=require"

# Core secrets (required at boot — server refuses to start if missing/too short).
# Generate strong, unique values per environment, e.g.: openssl rand -hex 32
# The CHANGE_ME_IN_PRODUCTION sentinel is explicitly rejected in production.
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"
REFRESH_SECRET="CHANGE_ME_IN_PRODUCTION"
RESET_PASSWORD_SECRET="CHANGE_ME_IN_PRODUCTION"
COOKIE_SECRET="CHANGE_ME_IN_PRODUCTION"

# Public URL of the frontend (used for CORS + password-reset links).
FRONTEND_URL="http://localhost:3002"

# Mobile device attestation enforcement (Play Integrity / App Attest).
# Leave false until a cryptographic verification provider is wired; when set to
# true, mobile requests are rejected until that verifier is configured.
MOBILE_ATTESTATION_ENABLED="false"

# Policy engine enforcement mode. "strict" (default) hard-blocks SoD, role, and
# reviewer-lock violations. 3-axis state-transition checks are shadow-logged
# until those columns are wired into the service. Set "shadow" to log only.
POLICY_ENFORCEMENT_MODE="strict"

# Proxy trust for deriving the real client IP (rate limiting, audit). Leave
# unset to trust nothing (req.ip = socket peer). Behind a load balancer, set the
# exact number of proxy hops (e.g. "1"); avoid "true" (trusts spoofable XFF).
# TRUST_PROXY="1"

# AWS S3 Configuration for Pre-signed URLs
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="mock_access_key"
AWS_SECRET_ACCESS_KEY="mock_secret_key"
AWS_S3_BUCKET="spendos-receipts"

# Email Configuration (e.g. Resend, Postmark, SES)
EMAIL_PROVIDER="resend"
EMAIL_API_KEY="re_mock12345"
EMAIL_FROM="finance@spendos.com"
