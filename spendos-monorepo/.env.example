POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=spendos
DATABASE_URL=postgresql://postgres:your_secure_db_password@db:5432/spendos?schema=public
REDIS_PASSWORD=your_secure_redis_password
REDIS_URL=redis://:your_secure_redis_password@redis:6379
JWT_SECRET=your_secure_jwt_secret_min_32_chars
REFRESH_SECRET=your_secure_refresh_secret_min_32_chars
COOKIE_SECRET=your_secure_cookie_secret_min_32_chars
FRONTEND_URL=https://dashboard.spendos.internal
NEXT_PUBLIC_API_URL=https://api.spendos.internal
RESEND_API_KEY=re_your_resend_api_key
